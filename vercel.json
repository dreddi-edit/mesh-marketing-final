{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.try-mesh.com" }],
      "destination": "https://try-mesh.com/:path*",
      "permanent": true
    },
    { "source": "/index.html", "destination": "/", "permanent": true },
    { "source": "/features.html", "destination": "/features", "permanent": true },
    { "source": "/quickstart.html", "destination": "/quickstart", "permanent": true },
    { "source": "/benchmarks.html", "destination": "/benchmarks", "permanent": true },
    { "source": "/mesh-animation", "destination": "/animation", "permanent": true }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/animation", "destination": "/mesh-animation.html" }
  ],
  "headers": [
    {
      "source": "/assets/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/animation",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
      ]
    }
  ]
}
